APP_NAME="Sistem Manajemen Inventaris"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://inventaris-telkomsel.test

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ==========================================
# DATABASE
# Default: SQLite (paling praktis untuk Laravel Herd, tanpa perlu
# setup server MySQL/PostgreSQL terpisah). File database sudah
# disertakan di database/database.sqlite lengkap dengan data dummy.
# ==========================================
DB_CONNECTION=sqlite
# DB_DATABASE tidak perlu diisi -> otomatis memakai database/database.sqlite

# Jika ingin memakai MySQL, ganti baris di atas menjadi:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=inventaris_telkomsel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==========================================
# MAIL (dipakai untuk fitur Forgot Password)
# Untuk development, gunakan MAIL_MAILER=log
# agar link reset password tampil di storage/logs/laravel.log
# ==========================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@inventaris-telkomsel.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Ambang batas stok menipis untuk notifikasi dashboard
LOW_STOCK_THRESHOLD=5
